# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Required for server-side admin operations (invites, role changes)
# Get from Supabase Dashboard -> Project Settings -> API -> service_role key
# IMPORTANT: This is a SECRET. Never commit. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Vercel Cron — shared secret used by /api/cron/* routes (e.g. PROJ-5
# wizard-drafts purge). Vercel Cron sends `Authorization: Bearer $CRON_SECRET`
# on every scheduled invocation; the route handlers verify this header.
# Generate any 32+ character random string. Without it, cron jobs fail closed.
# CRON_SECRET=please-generate-a-32-char-random-string

# Sentry — error tracking (optional). Without DSN the SDK no-ops, no traffic is sent.
# Get from https://sentry.io -> Project -> Settings -> Client Keys (DSN).
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Source-map upload (CI/Vercel only — needs an auth token + org/project slugs):
# SENTRY_AUTH_TOKEN=sntrys_xxx
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# PROJ-3 — operation mode + AI hard-block.
# Both are read server-side only; do NOT prefix with NEXT_PUBLIC_.
#
# OPERATION_MODE = "shared" | "standalone"  (default: "shared")
#   "shared"     — multi-tenant SaaS (the default V3 deployment).
#   "standalone" — enterprise on-prem / single-tenant. The TenantSwitcher
#                  hides itself unconditionally; UI affordances that imply
#                  "many tenants" collapse.
#   Anything other than the literal "standalone" (case-insensitive) falls
#   back to "shared" — typo-safe.
# OPERATION_MODE=standalone
#
# EXTERNAL_AI_DISABLED = "true" | anything else  (default: false)
#   Hard kill-switch for outbound LLM calls. PROJ-12 will check this before
#   loading any external provider. Independent of OPERATION_MODE: a SaaS
#   tenant can also opt-in for compliance reasons. Class-3 redaction
#   (PROJ-12) remains the primary defense; this is the second, blanket
#   layer. Strict opt-in: only the literal "true" enables the block.
# EXTERNAL_AI_DISABLED=true

# PROJ-12 — Anthropic provider for KI suggestions.
# Server-side only. Without ANTHROPIC_API_KEY the router falls back to the
# deterministic Stub provider (so tests, demos, and stand-alone setups
# without an external key remain functional). The model defaults to
# Claude Opus 4.7 — set ANTHROPIC_MODEL to switch (e.g. claude-sonnet-4-6
# for cheaper/faster runs).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# PROJ-14 — Connector framework: encryption key for tenant_secrets.
# Required for the credential UI to work end-to-end. Without this key the
# /konnektoren UI lists every connector with status `error: encryption_unavailable`
# and refuses to write tenant_secrets.
# Generate any 32+ character random string and store it as a server-secret
# in Vercel + Supabase. NEVER prefix NEXT_PUBLIC_.
# SECRETS_ENCRYPTION_KEY=please-generate-a-32-char-random-string

# PROJ-13 — Resend email provider for the communication center.
# Without RESEND_API_KEY the email channel falls back to a deterministic
# Stub adapter that marks messages as "sent" without contacting an external
# server. The UI surfaces a clear "Demo mode" banner in that case so nobody
# mistakes the Stub send for a real one.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@your-domain.tld

# PROJ-31 — Approval-Gates Magic-Link token signature.
# HMAC-SHA256 secret for signing approval-link tokens. Min 32 chars.
# Generate with `openssl rand -base64 32`. NEVER prefix NEXT_PUBLIC_.
# Without this, the /api/projects/.../approval routes throw at submit time
# with a clear "APPROVAL_TOKEN_SECRET is not set" message.
# APPROVAL_TOKEN_SECRET=please-generate-a-32-char-random-string

# PROJ-31 — Public base URL embedded in approval Magic-Link mails.
# Falls back to https://projektplattform-v3.vercel.app if unset.
# NEXT_PUBLIC_BASE_URL=https://projektplattform-v3.vercel.app

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
